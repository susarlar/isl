# Environment Configuration Example
# Copy this file to .env and fill in your values

# Groq API Configuration
# ======================
# Get your API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model Selection
# Available models:
# - llama-3.1-70b-versatile (recommended, balanced speed/quality)
# - llama-3.1-8b-instant (fastest, good quality)
# - mixtral-8x7b-32768 (large context window)
GROQ_MODEL=llama-3.1-70b-versatile

# Model Parameters
# ================
TEMPERATURE=0.1
MAX_TOKENS=1024
TOP_P=0.9

# Embedding Configuration
# =======================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Chunking Configuration
# ======================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_CHUNKS_PER_DOC=100

# Retrieval Configuration
# =======================
TOP_K_DOCUMENTS=5
SIMILARITY_THRESHOLD=0.7
RERANK_ENABLED=false

# Reproducibility Seeds
# =====================
RANDOM_SEED=42
EMBEDDING_SEED=42
EVAL_SEED=42
NUMPY_SEED=42
TORCH_SEED=42

# Application Settings
# ====================
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Vector Store Settings
# =====================
VECTOR_STORE_PATH=data/vector_store
INDEX_TYPE=FLAT
# For large datasets, use: INDEX_TYPE=IVF

# Cache Settings
# ==============
ENABLE_CACHE=true
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000

# API Settings (if using FastAPI)
# ================================
API_HOST=localhost
API_PORT=8000
API_WORKERS=4

# Evaluation Settings
# ===================
TEST_DATASET_PATH=data/test_queries.json
EVALUATION_OUTPUT_PATH=data/evaluation_results.json
EVALUATION_SAMPLE_SIZE=200

# Monitoring and Logging
# ======================
ENABLE_METRICS=true
METRICS_PORT=9090
LOG_FILE=logs/app.log
LOG_ROTATION=daily

# Performance Settings
# ====================
MAX_CONCURRENT_REQUESTS=50
REQUEST_TIMEOUT_SECONDS=30
BATCH_SIZE=32

# Development Settings
# ====================
HOT_RELOAD=true
ENABLE_PROFILING=false
