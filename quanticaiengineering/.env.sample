# ============================================================================
# Isekai Slow Life — Fellow Power Advisor
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ============================================================================

# ---- LLM Provider ----------------------------------------------------------
# Use "anthropic" (recommended) or "groq" (legacy fallback)
LLM_PROVIDER=anthropic

# ---- Anthropic / Claude ----------------------------------------------------
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
# Cheapest current Claude model (Haiku 4.5)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---- Groq (only if LLM_PROVIDER=groq) --------------------------------------
# GROQ_API_KEY=gsk_REPLACE_ME
# GROQ_MODEL=llama-3.3-70b-versatile

# ---- LLM Generation Params -------------------------------------------------
TEMPERATURE=0.1
MAX_TOKENS=1024
TOP_P=0.9

# ---- App Authentication ----------------------------------------------------
# Flask session signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_long_random_hex_string
# Shared password for guild members
APP_PASSWORD=chattyalmighty2026

# ---- Embeddings (local, no API key needed) --------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ---- Chunking & Retrieval --------------------------------------------------
CHUNK_SIZE=1500
CHUNK_OVERLAP=300
TOP_K_DOCUMENTS=10
SIMILARITY_THRESHOLD=0.7

# ---- Vector Store ----------------------------------------------------------
VECTOR_STORE_PATH=data/vector_store
INDEX_TYPE=FLAT

# ---- App Settings ----------------------------------------------------------
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ---- Logging ---------------------------------------------------------------
LOG_FILE=logs/app.log
# Disk-based per-user chat history (JSONL)
CHAT_HISTORY_FILE=logs/chat_history.jsonl

# ---- Reproducibility -------------------------------------------------------
RANDOM_SEED=42
